
<%- include('./layouts/header') %>

<form action="/user/book-appointment" method="POST" class="lg-form">
    <div>
        <label for="patientEmail">Patient's Email:</label>
        <input type="email" id="patientEmail" name="patientEmail" value="<%= patient.email %>" >
    </div>
    <div>
        <label for="doctorEmail">Doctor's Email:</label>
        <input type="email" id="doctorEmail" name="doctorEmail" value="<%= doctor.email %>" >
    </div>
    <div>
        <label for="date">Date of Consultation:</label>
        <input type="datetime-local" id="date" name="date" >
    </div>
    <div>
        <label for="reason">Reason for Consultation:</label>
        <textarea id="reason" name="reason" rows="4" ></textarea>
    </div>
   
    <button type="submit">Confirmer</button>
    <button ><a href="/user/doctors"></a>Annuler</button>
</form>

<%- include('./layouts/footer') %>
