<%- include('./layouts/header') %>
<form class="login" action="/auth/login" method="post" class="lg-form">
  <div class='container'>
    <h1 id="id2">Login</h1>
  </div>
  <div>
    <label id="id1" for="email">Email/Username</label>
    <input type="email" name="email" id="email" />
  </div>
  <div>
    <label id="id1" for="password">Password</label>
    <input type="password" name="password" id="password" />
  </div>
  <div>
    <button class="btn submit">Login</button>
  </div>
  
  <div>
    <p>
      Don't have an account? <span><a href="/auth/register">Register</a></span>
    </p>
  </div>
</form>
<br />
<%- include('./layouts/footer') %>
